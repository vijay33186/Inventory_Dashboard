@model IEnumerable<Inventory>

@{
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

    body {
        background: #f4f6f9;
    }

    .card {
        border-radius: 10px;
        border: none;
    }

    .table td {
        vertical-align: middle;
    }

    .actions a {
        margin-right: 5px;
    }

</style>
<style>
    .card:hover {
        transform: scale(1.03);
        transition: 0.3s;
    }
</style>
<script>
    setTimeout(function () {
        var alert = document.querySelector(".alert-success");
        if (alert) {
            alert.style.display = "none";
        }
    }, 3000);
</script>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="text-primary mb-0">Inventory Dashboard</h2>

        <div>
            <a asp-action="Create" class="btn btn-success me-2">Add Item</a>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">Logout</a>
        </div>

    </div>
    <!-- DASHBOARD CARDS -->

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card bg-primary text-white shadow">
                <div class="card-body">

                    <h6>Total Items</h6>
                    <h3>@ViewBag.TotalItems</h3>

                </div>
            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-success text-white shadow">
                <div class="card-body">

                    <h6>Total Quantity</h6>
                    <h3>@ViewBag.TotalQuantity</h3>

                </div>
            </div>

        </div>

        <div class="col-md-4">

            <div class="card bg-warning text-white shadow">
                <div class="card-body">

                    <h6>Total Value</h6>

                    <h3>
                        ₹ @String.Format(
                                                new System.Globalization.CultureInfo("en-IN"),
                                                "{0:N2}",
                                                ViewBag.TotalValue)
                    </h3>

                </div>
            </div>

        </div>

    </div>

    <!-- SEARCH + SORT -->

    <div class="card shadow mb-3">
        <div class="card-body">

            <form method="get" class="row g-2">

                <div class="col-md-4">

                    <input type="text"
                           name="searchString"
                           class="form-control"
                           placeholder="Search item..." />

                </div>

                <div class="col-md-3">

                    <select name="sortOrder" class="form-control">

                        <option value="">Sort</option>
                        <option value="price">Price</option>
                        <option value="qty">Quantity</option>

                    </select>

                </div>

                <div class="col-md-2">

                    <button class="btn btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>

                </div>

            </form>

        </div>
    </div>

    <!-- TABLE -->

    <div class="card shadow">

        <div class="card-body">

            @if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">

        <strong>Success!</strong> @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>Item Name</th>
                        <th class="text-center">Quantity</th>
                        <th>Price</th>
                        <th style="width:220px;">Actions</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {

                        <tr>

                            <td>@item.Itemname</td>

                            <td class="text-center">@item.Quantity</td>

                            <td>
                                ₹ @String.Format(
                                                            new System.Globalization.CultureInfo("en-IN"),
                                                            "{0:N2}",
                                                            item.Price)
                        </td>

                            <td class="actions">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm"> <i class="bi bi-pencil"></i> </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm"> <i class="bi bi-eye"></i> </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm"> <i class="bi bi-trash"></i> </a>

                            </td>

                        </tr>

                                        }

                </tbody>

            </table>

            <!-- PAGINATION -->

            <nav>

                <ul class="pagination">

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {

                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                            <a class="page-link" href="?page=@i">
                                @i
                            </a>

                        </li>

                    }

                </ul>

            </nav>

        </div>

    </div>

    <!-- CHART -->

    <div class="card shadow mt-4">

        <div class="card-body">

            <h5>Inventory Quantity Chart</h5>

            <canvas id="inventoryChart"></canvas>

        </div>

    </div>

</div>

<script>

    var ctx = document.getElementById('inventoryChart');

    var chart = new Chart(ctx, {

    type: 'bar',

    data: {

    labels: [
    @foreach (var item in Model)
    {
        <text>"@item.Itemname",</text>
    }
    ],

    datasets: [{

    label: 'Stock Quantity',

    data: [
    @foreach (var item in Model)
    {
        <text>@item.Quantity,</text>
    }
    ]

    }]

    }

    });

</script>
